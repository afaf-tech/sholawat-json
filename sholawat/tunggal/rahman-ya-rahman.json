{
  "source": "Majelis Rasulullah",
  "name": "رحمن يا رحمن",
  "latin": "Rahman Ya Rahman",
  "text": {
    "1": {
      "arabic": "رَحْمٰن يَا رَحْمٰن",
      "latin": "Raḥmān Yā Raḥmān"
    },
    "2": {
      "arabic": "سَاعِدْنِيْ يَا رَحْمٰن",
      "latin": "Sā’idnī Yā Raḥmān"
    },
    "3": {
      "arabic": "اِشْرَحْ صَدْرِيْ قُرْآن",
      "latin": "Isyroḥ ṣodrī Qur-ān"
    },
    "4": {
      "arabic": "اِمْلَأْ قَلْبِيْ قُرْآن",
      "latin": "Imla’ qolbī Qur-ān"
    },
    "5": {
      "arabic": "وَاسْقِيْ حَيَاتِيْ قُرْآن",
      "latin": "Wasqī ḥayātī Qur-ān"
    },
    "6": {
      "arabic": "لِلّٰهِ لِلّٰهِ يَهْفُوْ أَمَلِيْ لِلّٰهِ",
      "latin": "Lillāh lillāh yahfū amalī lillāh"
    },
    "7": {
      "arabic": "وَلِحِفْظِ كِتَابِ اللهِ",
      "latin": "Wa liḥifdhi kitābillāh"
    },
    "8": {
      "arabic": "مِنْ أَوَّلِ بِسْمِ اللهِ",
      "latin": "Min awwali bismillāh"
    },
    "9": {
      "arabic": "لِلْخَتْمِ وَلِلرِّضْوَان",
      "latin": "Lil khotmi wa lir-riḍwān"
    },
    "10": {
      "arabic": "يَا نُوْرُ يَا نُوْرُ",
      "latin": "Yā Nūr Yā Nūr"
    },
    "11": {
      "arabic": "يَا مُحْكَمُ يَا تَنْزِيْلُ",
      "latin": "Yā muḥkamu yā tanzīl"
    },
    "12": {
      "arabic": "لِمُحَمَّدٍ عَنْ جِبْرِيْل",
      "latin": "Li Muḥammadin ‘an Jibrīl"
    },
    "13": {
      "arabic": "مِنْ رَبِّ الْعَرْشِ دَلِيْل",
      "latin": "Min Rabbil ‘arsyi dalīl"
    },
    "14": {
      "arabic": "لِلْعَالَمِ وَالْإِنْسَان",
      "latin": "Lil ‘ālami wal insān"
    },
    "15": {
      "arabic": "تَكْبِيْرُ تَكْبِيْرُ",
      "latin": "Takbīr takbīr"
    },
    "16": {
      "arabic": "لِلْحَافِظِ وَهُوَ صَغِيْر",
      "latin": "Lil ḥāfidzi wa huwa ṣoghīr"
    },
    "17": {
      "arabic": "وَضَّاءُ الْعَيْنِ قَرِيْرُ",
      "latin": "Waḍḍā-ul ‘aini qarīr"
    },
    "18": {
      "arabic": "يَحْمِلُ فَجْرًا لِيُنِيْر",
      "latin": "Yaḥmilu fajron liyunīr"
    },
    "19": {
      "arabic": "بِتِلَاوَتِهِ الْأَكْوَان",
      "latin": "Bitilāwatihil akwān"
    },
    "20": {
      "arabic": "اَللّٰهُ اَللّٰهُ اَللّٰهُمَّ اجْمَعْنَا",
      "latin": "Allāh Allāh Allāhummajma’nā"
    },
    "21": {
      "arabic": "بِكِتَابِكَ وَ انْفَعْنَا",
      "latin": "Bikitābika wanfa’nā"
    },
    "22": {
      "arabic": "وَاجْعَلْهُ لَنَا حِصْنًا",
      "latin": "Waj’alhu lanā ḥiṣnā"
    },
    "23": {
      "arabic": "وَهُدًى أَبَدًا وَأَمَان",
      "latin": "Wa hudan abadan wa amān"
    }
  },
  "translations": {
    "id": {
      "name": "Wahai Yang Maha Pengasih",
      "text": {
        "1": "(Wahai Yang Maha Pengasih)",
        "2": "Bantulah aku.. Wahai Yang Maha Pengasih",
        "3": "Lapangkan dadaku untuk (memahami) Al-Qur’an,",
        "4": "Penuhi hati ini (dengan cinta) kepada Al-Qur’an,",
        "5": "Sirami hidupku dengan Al-Qur’an",
        "6": "Hanya untuk Allah, begitu mendalam keinginanku karena Allah…",
        "7": "Bisakah aku menjaga (mempelajari) Al-Qur’an",
        "8": "Dimulai dengan “Bismillah…”,",
        "9": "Hingga penutupan (Al-Qur’an) dan mendapat keridho’an",
        "10": "Wahai Penerang.. Wahai Penerang..",
        "11": "Wahai yang menetapkan juga menurunkan (Al-Qur’an)",
        "12": "Untuk Muhammad (SAW), melalui Jibril,",
        "13": "Petunjuk dari Tuhan yang menguasai arsy",
        "14": "Bagi semesta alam dan manusia",
        "15": "Bertakbirlah… bertakbirlah…",
        "16": "Bagi yang memepelajari (Al-Qur’an) sejak kecil",
        "17": "Menerangi mata dengan ketenangan dan kedamaian,",
        "18": "Bersinar laksana cahaya subuh",
        "19": "Alam semesta yang diperkaya dengan ayat-ayat Nya",
        "20": "Wahai Allah.. kumpulkanlah kami bersama-sama,",
        "21": "Dengan barokah dari kitab (Al-Qur’an)-Mu dan berilah manfaat pada kami",
        "22": "Menjadi benteng/pertahanan kita,",
        "23": "Petunjuk yang kekal abadi dan keamanan"
      }
    }
  },
  "last_updated": "2026-03-15"
}